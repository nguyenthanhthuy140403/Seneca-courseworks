<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Add your meta tags and CSS links here -->
</head>
<body tabindex="-1">
  <div class="navbar bg-base-100">
    <div class="flex-1">
      <a class="<%= (page == '/lego/sets') ? 'active' : '' %> btn btn-ghost normal-case text-xl" href="/lego/sets">Sets</a>
    </div>
    <!-- Add other navigation links here -->
  </div>

  <br />

  <div class="container mx-auto">
    <div class="hero bg-base-200 rounded-lg p-6">
      <div class="hero-content text-center">
        <h1 class="text-5xl font-bold">Collection</h1>
        <!-- Add filter links here (e.g., by theme) -->
      </div>
    </div>

    <br />

    <table class="table w-full">
      <thead>
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Theme</th>
          <th>Year</th>
          <th>Number of Parts</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>
        <% sets.forEach(set => { %>
          <tr>
            <td><img src="<%= set.img_url %>" alt="<%= set.name %>" class="w-8 h-8" /></td>
            <td><%= set.name %></td>
            <td><a href="/lego/sets?theme=<%= set.theme %>" class="btn btn-primary"><%= set.theme %></a></td>
            <td><%= set.year %></td>
            <td><%= set.num_parts %></td>
            <td><a href="/lego/sets/<%= set.set_num %>" class="btn btn-primary">Details</a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</body>
</html>
