<!-- /views/addSet.ejs -->

<%- include('partials/navbar', { page: '/lego/addSet' }) %>

<div class="container mt-4">
  <h1>Add Set</h1>

  <form action="/lego/addSet" method="post">
    <div class="mb-3">
      <label for="name" class="form-label">Name</label>
      <input type="text" class="form-control" id="name" name="name" required>
    </div>

    <div class="mb-3">
      <label for="year" class="form-label">Year</label>
      <input type="number" class="form-control" id="year" name="year" required>
    </div>

    <div class="mb-3">
      <label for="num_parts" class="form-label">Number of Parts</label>
      <input type="number" class="form-control" id="num_parts" name="num_parts" required>
    </div>

    <div class="mb-3">
      <label for="img_url" class="form-label">Image URL</label>
      <input type="url" class="form-control" id="img_url" name="img_url" required>
    </div>

    <div class="mb-3">
      <label for="theme_id" class="form-label">Theme</label>
      <select class="form-select" id="theme_id" name="theme_id" required>
        <% themes.forEach(theme => { %>
          <option value="<%= theme.id %>"><%= theme.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="mb-3">
      <label for="set_num" class="form-label">Set Number</label>
      <input type="text" class="form-control" id="set_num" name="set_num" required>
    </div>

    <button type="submit" class="btn btn-primary">Submit</button>
  </form>
</div>
